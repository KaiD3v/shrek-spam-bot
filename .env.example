# Discord
DISCORD_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GUILD_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp API (servico npm run wpp)
WPP_PORT=3001
WPP_API_URL=http://localhost:3001
WPP_API_SECRET=shrek-wpp-secret

# Destino das mensagens (/enviar e /shrek)
WHATSAPP_TARGET=5511999999999

# Roteiro Shrek: intervalo entre mensagens (ms)
SHREK_DELAY_MS=300

# WhatsApp: tentativas de inicializacao e timeouts (ms)
WPP_INIT_RETRIES=3
WPP_READY_TIMEOUT_MS=120000
WPP_SEND_READY_WAIT_MS=10000

# Opcional: Chrome/Chromium do sistema (deixe vazio para usar o bundled do Puppeteer)
# CHROME_EXECUTABLE_PATH=/usr/bin/chromium
